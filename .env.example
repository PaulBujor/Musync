# Database (Postgres or Sqlite)
Database__Provider=Sqlite
ConnectionStrings__Sqlite=Data Source=musync.db
ConnectionStrings__Postgres=Host=localhost;Database=musync;Username=musync;Password=musync

# Spotify API credentials (PKCE public client — no secret needed)
Spotify__ClientId=your-client-id
Spotify__QueuePlaylistId=your-playlist-id

# Tidal API credentials (required for imports from Tidal)
Tidal__ClientId=your-tidal-client-id
