# Database
ConnectionStrings__Postgres=Host=localhost;Database=musync;Username=musync;Password=musync

# Valkey / Redis cache (for Docker Compose, use: valkey:6379)
ConnectionStrings__Valkey=localhost:6379

# Spotify API credentials
Spotify__ClientId=your-client-id
Spotify__ClientSecret=your-client-secret
Spotify__QueuePlaylistId=your-playlist-id

# Tidal API credentials (required for import-tidal)
Tidal__ClientId=your-tidal-client-id
Tidal__ClientSecret=your-tidal-client-secret
